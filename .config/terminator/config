[global_config]
  borderless = True
  inactive_color_offset = 1.0
[keybindings]
[profiles]
  [[default]]
    background_darkness = 0.75
    background_type = transparent
    font = Anonymous Pro 18
    scrollback_infinite = True
    scrollbar_position = hidden
    show_titlebar = False
    use_system_font = False
[layouts]
  [[default]]
    [[[window0]]]
      parent = ""
      type = Window
    [[[child1]]]
      parent = window0
      profile = default
      type = Terminal
[plugins]
